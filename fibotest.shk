^ i = 0

create Chapter.int i
create Task.intro INTROR
create Task.set SETR
create Task.add ADDR
create Task.smlr SMLR

^ init
switch i
go SETR int 0
run SETR

^ print
ready INTROR
run INTROR

startstamp LOOP
    clrtsk INTROR
    clrtsk ADDR
    clrtsk SMLR

    ready ADDR
    go ADDR int 1
    run ADDR

    ready INTROR
    run INTROR

    ^ 比较 i 和 10
    switch i
    ready SMLR
    go SMLR int 10
    run SMLR

    ifstamp SMLR LOOP
endstamp

backstamp LOOP